# ============================================================================
# .htaccess — production configuration for box.co.il (Apache shared hosting).
#
# This file is copied verbatim into `out/` by Next.js static export, BUT the
# GitHub deploy action excludes it (.htaccess on the server is the source of
# truth — it is edited directly via cPanel File Manager). Keep this template
# in sync with the server so the local copy matches reality.
#
# Sections:
#   1. Domain redirect (growingfamily.co.il -> alexrysin.co.il)
#   2. Force HTTPS (http -> https)
#   3. Security headers (CSP, HSTS, etc.)
#   4. Clean URLs (Next.js static export trailing-slash routing)
#   5. Aggressive caching for static assets
#   6. LiteSpeed compatibility
# ============================================================================

# ----------------------------------------------------------------------------
# 1. Redirect old domain -> new domain (preserves SEO from growingfamily.co.il)
# ----------------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTP_HOST} ^(www\.)?growingfamily\.co\.il$ [NC]
  RewriteRule ^(.*)$ https://alexrysin.co.il/$1 [R=301,L]
</IfModule>

# ----------------------------------------------------------------------------
# 2. Force HTTPS — redirect all http:// traffic to https://
# ----------------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# ----------------------------------------------------------------------------
# 3. Security headers
# ----------------------------------------------------------------------------
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS

  # CSP — adjust if you add analytics or 3rd-party scripts later.
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https:; connect-src 'self' https://formspree.io; frame-ancestors 'self'; form-action 'self' https://formspree.io; base-uri 'self';"
</IfModule>

# ----------------------------------------------------------------------------
# 4. Clean URLs — serve index.html from directories and handle 404
# ----------------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # If a request is for an existing file or directory, serve it as-is.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Otherwise, try adding .html (e.g. /about -> /about.html if it exists)
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]

  ErrorDocument 404 /404.html
</IfModule>

# ----------------------------------------------------------------------------
# 5. Cache static assets aggressively
# ----------------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png  "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/css   "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# ----------------------------------------------------------------------------
# 6. LiteSpeed compatibility
# ----------------------------------------------------------------------------
<IfModule LiteSpeed>
  SetEnv noabort 1
</IfModule>
